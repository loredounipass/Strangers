# Server environment variables
# Port the server listens on
PORT=8000

# Comma-separated allowed origins for CORS (add your client URLs)
ALLOWED_ORIGINS=https://3bd1-190-107-209-205.ngrok-free.app

# TURN server with credentials (optional). Replace with your TURN provider values.
# Example using a publicly-known test TURN (used in many samples). Replace in production.
TURN_URL=turn:turn.bistri.com:80
TURN_USERNAME=homeo
TURN_CREDENTIAL=homeo

# Other optional env flags
# LOG_LEVEL=info