# Server environment variables
# Port the server listens on
PORT=8000

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Comma-separated allowed origins for CORS (add your client URLs)
ALLOWED_ORIGINS=https://ctqkwg7k-5173.use2.devtunnels.ms

# TURN server — Open Relay (Metered) — gratuito y sin registro
# Funciona en UDP:3478, TCP:3478 y TLS:5349 para max compatibilidad
TURN_URL=turn:openrelay.metered.ca:80
TURN_USERNAME=openrelayproject
TURN_CREDENTIAL=openrelayproject

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Logging configuration
LOG_LEVEL=INFO
LOG_COLORS=true
LOG_JSON=false

# Other optional env flags
# NODE_ENV=production